rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    // Preserve the previous study's authenticated autosave access.
    match /prolific_annotations/{document} {
      allow create, read, update: if signedIn();
    }

    // Contains only SHA-256 participant keys and the ten slot claims.
    match /countermem_v3_admin/countermem-gov-v3 {
      allow read: if signedIn();
      allow create, update: if signedIn()
        && request.resource.data.capacity == 10
        && request.resource.data.assignments.size() <= 10
        && request.resource.data.claimed_slots.size() <= 10;
    }

    match /countermem_v3_admin/countermem-simplified-balanced-v2 {
      allow read: if signedIn();
      allow create, update: if signedIn()
        && request.resource.data.capacity == 10
        && request.resource.data.assignments.size() <= 10
        && request.resource.data.claimed_slots.size() <= 10;
    }

    // A participant can read/write only the document created by their
    // persistent anonymous Firebase identity.
    match /countermem_v3_annotations/{participantHash} {
      allow create: if signedIn() && request.resource.data.uid == request.auth.uid;
      // A first-time participant must be able to confirm that their hashed
      // document does not exist before creating it. Queries/listing remain
      // forbidden, and an existing document is readable only by its owner.
      // The public download page lists all annotation documents after anonymous
      // sign-in. Writes remain restricted to each participant's original UID.
      allow get, list: if signedIn();
      allow update: if signedIn() && resource.data.uid == request.auth.uid
        && request.resource.data.uid == request.auth.uid;
      allow delete: if signedIn() && resource.data.uid == request.auth.uid;
    }


    match /countermem_simplified_v2_annotations/{participantHash} {
      allow create: if signedIn() && request.resource.data.uid == request.auth.uid;
      allow get: if signedIn() && resource.data.uid == request.auth.uid;
      allow list: if false;
      allow update: if signedIn() && resource.data.uid == request.auth.uid
        && request.resource.data.uid == request.auth.uid;
      allow delete: if signedIn() && resource.data.uid == request.auth.uid;
    }

    match /countermem_v3_admin/countermem-simplified-balanced-v3-15 {
      allow read: if signedIn();
      allow create, update: if signedIn()
        && request.resource.data.capacity == 20
        && request.resource.data.assignments.size() <= 20
        && request.resource.data.claimed_slots.size() <= 20;
    }

    match /countermem_simplified_v3_15_annotations/{participantHash} {
      allow create: if signedIn() && request.resource.data.uid == request.auth.uid;
      allow get: if signedIn() && resource.data.uid == request.auth.uid;
      allow list: if false;
      allow update: if signedIn() && resource.data.uid == request.auth.uid
        && request.resource.data.uid == request.auth.uid;
      allow delete: if signedIn() && resource.data.uid == request.auth.uid;
    }
  }
}
